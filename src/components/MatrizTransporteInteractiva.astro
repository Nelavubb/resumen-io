---
---

<div class="bg-slate-900 border border-slate-800 rounded-2xl overflow-hidden flex flex-col shadow-xl">
  <div class="bg-slate-950/50 p-4 border-b border-slate-800 flex items-center justify-between">
    <div class="flex items-center gap-2">
      <span class="flex h-3 w-3 relative">
        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-blue-400 opacity-75"></span>
        <span class="relative inline-flex rounded-full h-3 w-3 bg-blue-500"></span>
      </span>
      <span class="text-blue-400 font-mono text-sm font-bold uppercase tracking-wider">Simulador: Esquina Noroeste</span>
    </div>
  </div>

  <div class="p-6 flex flex-col items-center justify-center bg-slate-950/30 overflow-x-auto">
    <div class="grid grid-cols-6 gap-2 min-w-[600px] font-mono text-center text-sm">
      <div class="p-2 text-slate-600 font-bold"></div>
      <div class="p-2 text-slate-400 font-bold border-b border-slate-800">C1</div>
      <div class="p-2 text-slate-400 font-bold border-b border-slate-800">C2</div>
      <div class="p-2 text-slate-400 font-bold border-b border-slate-800">C3</div>
      <div class="p-2 text-slate-400 font-bold border-b border-slate-800">C4</div>
      <div class="p-2 text-blue-400 font-bold border-b border-slate-800 bg-blue-500/10 rounded-t-lg">Oferta</div>

      <div class="p-3 text-slate-400 font-bold flex items-center justify-end pr-2 border-r border-slate-800" id="row-0-label">P1</div>
      <div id="cell-0-0" class="t-cell relative p-3 bg-slate-900 border border-slate-800 rounded-lg flex items-center justify-center min-h-[60px] transition-all"><span class="absolute top-1 right-2 text-xs text-slate-500">$8</span><span class="val text-xl font-bold text-cyan-400 opacity-0">0</span></div>
      <div id="cell-0-1" class="t-cell relative p-3 bg-slate-900 border border-slate-800 rounded-lg flex items-center justify-center min-h-[60px] transition-all"><span class="absolute top-1 right-2 text-xs text-slate-500">$6</span><span class="val text-xl font-bold text-cyan-400 opacity-0">0</span></div>
      <div id="cell-0-2" class="t-cell relative p-3 bg-slate-900 border border-slate-800 rounded-lg flex items-center justify-center min-h-[60px] transition-all"><span class="absolute top-1 right-2 text-xs text-slate-500">$10</span><span class="val text-xl font-bold text-cyan-400 opacity-0">0</span></div>
      <div id="cell-0-3" class="t-cell relative p-3 bg-slate-900 border border-slate-800 rounded-lg flex items-center justify-center min-h-[60px] transition-all"><span class="absolute top-1 right-2 text-xs text-slate-500">$9</span><span class="val text-xl font-bold text-cyan-400 opacity-0">0</span></div>
      <div id="sup-0" class="p-3 text-white font-bold bg-blue-500/10 border-l border-blue-500/20 flex items-center justify-center transition-all">35</div>

      <div class="p-3 text-slate-400 font-bold flex items-center justify-end pr-2 border-r border-slate-800" id="row-1-label">P2</div>
      <div id="cell-1-0" class="t-cell relative p-3 bg-slate-900 border border-slate-800 rounded-lg flex items-center justify-center min-h-[60px] transition-all"><span class="absolute top-1 right-2 text-xs text-slate-500">$9</span><span class="val text-xl font-bold text-cyan-400 opacity-0">0</span></div>
      <div id="cell-1-1" class="t-cell relative p-3 bg-slate-900 border border-slate-800 rounded-lg flex items-center justify-center min-h-[60px] transition-all"><span class="absolute top-1 right-2 text-xs text-slate-500">$12</span><span class="val text-xl font-bold text-cyan-400 opacity-0">0</span></div>
      <div id="cell-1-2" class="t-cell relative p-3 bg-slate-900 border border-slate-800 rounded-lg flex items-center justify-center min-h-[60px] transition-all"><span class="absolute top-1 right-2 text-xs text-slate-500">$13</span><span class="val text-xl font-bold text-cyan-400 opacity-0">0</span></div>
      <div id="cell-1-3" class="t-cell relative p-3 bg-slate-900 border border-slate-800 rounded-lg flex items-center justify-center min-h-[60px] transition-all"><span class="absolute top-1 right-2 text-xs text-slate-500">$7</span><span class="val text-xl font-bold text-cyan-400 opacity-0">0</span></div>
      <div id="sup-1" class="p-3 text-white font-bold bg-blue-500/10 border-l border-blue-500/20 flex items-center justify-center transition-all">50</div>

      <div class="p-3 text-slate-400 font-bold flex items-center justify-end pr-2 border-r border-slate-800" id="row-2-label">P3</div>
      <div id="cell-2-0" class="t-cell relative p-3 bg-slate-900 border border-slate-800 rounded-lg flex items-center justify-center min-h-[60px] transition-all"><span class="absolute top-1 right-2 text-xs text-slate-500">$14</span><span class="val text-xl font-bold text-cyan-400 opacity-0">0</span></div>
      <div id="cell-2-1" class="t-cell relative p-3 bg-slate-900 border border-slate-800 rounded-lg flex items-center justify-center min-h-[60px] transition-all"><span class="absolute top-1 right-2 text-xs text-slate-500">$9</span><span class="val text-xl font-bold text-cyan-400 opacity-0">0</span></div>
      <div id="cell-2-2" class="t-cell relative p-3 bg-slate-900 border border-slate-800 rounded-lg flex items-center justify-center min-h-[60px] transition-all"><span class="absolute top-1 right-2 text-xs text-slate-500">$16</span><span class="val text-xl font-bold text-cyan-400 opacity-0">0</span></div>
      <div id="cell-2-3" class="t-cell relative p-3 bg-slate-900 border border-slate-800 rounded-lg flex items-center justify-center min-h-[60px] transition-all"><span class="absolute top-1 right-2 text-xs text-slate-500">$5</span><span class="val text-xl font-bold text-cyan-400 opacity-0">0</span></div>
      <div id="sup-2" class="p-3 text-white font-bold bg-blue-500/10 border-l border-blue-500/20 rounded-br-lg flex items-center justify-center transition-all">40</div>

      <div class="p-3 text-emerald-400 font-bold bg-emerald-500/10 rounded-l-lg border-t border-emerald-500/20 flex items-center justify-end pr-2">Demanda</div>
      <div id="dem-0" class="p-3 text-white font-bold bg-emerald-500/10 border-t border-emerald-500/20 flex items-center justify-center transition-all">45</div>
      <div id="dem-1" class="p-3 text-white font-bold bg-emerald-500/10 border-t border-emerald-500/20 flex items-center justify-center transition-all">20</div>
      <div id="dem-2" class="p-3 text-white font-bold bg-emerald-500/10 border-t border-emerald-500/20 flex items-center justify-center transition-all">30</div>
      <div id="dem-3" class="p-3 text-white font-bold bg-emerald-500/10 border-t border-emerald-500/20 rounded-r-lg flex items-center justify-center transition-all">30</div>
      <div class="p-3 text-slate-600 font-bold flex items-center justify-center bg-slate-900/50 rounded-lg ml-2">125</div>
    </div>
  </div>

  <div class="p-6 border-t border-slate-800 bg-slate-900 flex flex-col md:flex-row gap-6 items-center justify-between">
    <div class="flex-1">
      <h3 id="trans-title" class="text-blue-400 font-bold mb-1 text-base">Paso 0: Matriz Inicial</h3>
      <p id="trans-desc" class="text-slate-300 font-light text-sm min-h-[40px]">
        Identificamos la oferta (azul) y la demanda (verde). Empezaremos asignando siempre en la celda disponible más a la izquierda y arriba (Noroeste).
      </p>
    </div>
    <div class="flex gap-3 shrink-0">
      <button id="trans-prev" class="px-4 py-2 bg-slate-800 hover:bg-slate-700 text-slate-300 text-sm rounded-lg border border-slate-700 transition-colors disabled:opacity-40 disabled:cursor-not-allowed">
        Anterior
      </button>
      <button id="trans-next" class="px-4 py-2 bg-blue-500 hover:bg-blue-400 text-slate-950 font-bold text-sm rounded-lg border border-blue-500 shadow-[0_0_15px_rgba(59,130,246,0.3)] transition-colors disabled:opacity-40 disabled:cursor-not-allowed">
        Siguiente
      </button>
    </div>
  </div>
</div>

<script>
  // Definición estricta de tipos
  interface StepTransporte {
    title: string;
    desc: string;
    allocs: Record<string, number>;
    supply: number[];
    demand: number[];
    active: string | null;
    crossedRows: number[];
    crossedCols: number[];
  }

  const steps: StepTransporte[] = [
    {
      title: "Paso 0: Matriz Inicial",
      desc: "Problema balanceado (Oferta 125 = Demanda 125). Empezamos en la Esquina Noroeste: Planta 1 a Ciudad 1.",
      allocs: {}, supply: [35, 50, 40], demand: [45, 20, 30, 30], active: null, crossedRows: [], crossedCols: []
    },
    {
      title: "Paso 1: Asignar P1 -> C1",
      desc: "Comparamos Oferta P1 (35) y Demanda C1 (45). Asignamos el mínimo: 35. La oferta de P1 se agota (tachamos fila P1). Restan 10 en demanda C1.",
      allocs: {"0-0": 35}, supply: [0, 50, 40], demand: [10, 20, 30, 30], active: "0-0", crossedRows: [0], crossedCols: []
    },
    {
      title: "Paso 2: Asignar P2 -> C1",
      desc: "Bajamos a P2. Comparamos Oferta P2 (50) con la Demanda restante de C1 (10). Asignamos 10. La demanda de C1 se cumple (tachamos columna C1).",
      allocs: {"0-0": 35, "1-0": 10}, supply: [0, 40, 40], demand: [0, 20, 30, 30], active: "1-0", crossedRows: [0], crossedCols: [0]
    },
    {
      title: "Paso 3: Asignar P2 -> C2",
      desc: "Nos movemos a la derecha (C2). Comparamos Oferta restante P2 (40) y Demanda C2 (20). Asignamos 20. La demanda de C2 se cumple (tachamos columna C2).",
      allocs: {"0-0": 35, "1-0": 10, "1-1": 20}, supply: [0, 20, 40], demand: [0, 0, 30, 30], active: "1-1", crossedRows: [0], crossedCols: [0, 1]
    },
    {
      title: "Paso 4: Asignar P2 -> C3",
      desc: "Nos movemos a C3. Oferta restante P2 (20) vs Demanda C3 (30). Asignamos 20. La oferta de P2 se agota (tachamos fila P2).",
      allocs: {"0-0": 35, "1-0": 10, "1-1": 20, "1-2": 20}, supply: [0, 0, 40], demand: [0, 0, 10, 30], active: "1-2", crossedRows: [0, 1], crossedCols: [0, 1]
    },
    {
      title: "Paso 5: Asignar P3 -> C3",
      desc: "Bajamos a P3. Oferta P3 (40) vs Demanda restante C3 (10). Asignamos 10. La demanda de C3 se cumple (tachamos columna C3).",
      allocs: {"0-0": 35, "1-0": 10, "1-1": 20, "1-2": 20, "2-2": 10}, supply: [0, 0, 30], demand: [0, 0, 0, 30], active: "2-2", crossedRows: [0, 1], crossedCols: [0, 1, 2]
    },
    {
      title: "Paso 6: Asignar P3 -> C4 (Final)",
      desc: "Movemos a C4. Queda exactamente Oferta P3 (30) y Demanda C4 (30). Asignamos 30. Ambas se agotan. ¡Solución inicial encontrada!",
      allocs: {"0-0": 35, "1-0": 10, "1-1": 20, "1-2": 20, "2-2": 10, "2-3": 30}, supply: [0, 0, 0], demand: [0, 0, 0, 0], active: "2-3", crossedRows: [0, 1, 2], crossedCols: [0, 1, 2, 3]
    }
  ];

  let stepIdx: number = 0;

  const btnNext = document.getElementById('trans-next') as HTMLButtonElement | null;
  const btnPrev = document.getElementById('trans-prev') as HTMLButtonElement | null;
  const titleEl = document.getElementById('trans-title') as HTMLElement | null;
  const descEl = document.getElementById('trans-desc') as HTMLElement | null;

  function renderStep(): void {
    const data = steps[stepIdx];
    
    if (titleEl) titleEl.textContent = data.title;
    if (descEl) descEl.textContent = data.desc;

    for(let i=0; i<3; i++) {
      const supEl = document.getElementById(`sup-${i}`) as HTMLElement | null;
      if(supEl) {
        supEl.textContent = data.supply[i].toString();
        if(data.supply[i] === 0) {
           supEl.classList.add('opacity-30', 'line-through');
        } else {
           supEl.classList.remove('opacity-30', 'line-through');
        }
      }
    }

    for(let i=0; i<4; i++) {
      const demEl = document.getElementById(`dem-${i}`) as HTMLElement | null;
      if(demEl) {
        demEl.textContent = data.demand[i].toString();
        if(data.demand[i] === 0) {
           demEl.classList.add('opacity-30', 'line-through');
        } else {
           demEl.classList.remove('opacity-30', 'line-through');
        }
      }
    }

    for(let r=0; r<3; r++) {
      for(let c=0; c<4; c++) {
        const key = `${r}-${c}`;
        const cell = document.getElementById(`cell-${key}`) as HTMLElement | null;
        if(!cell) continue;

        const valSpan = cell.querySelector('.val') as HTMLElement | null;
        const costSpan = cell.querySelector('.text-xs') as HTMLElement | null;
        
        cell.className = "t-cell relative p-3 bg-slate-900 border border-slate-800 rounded-lg flex items-center justify-center min-h-[60px] transition-all";
        
        if(valSpan) {
            valSpan.className = "val text-xl font-bold transition-all";
            if(data.allocs[key] !== undefined) {
                valSpan.textContent = data.allocs[key].toString();
                valSpan.classList.add('opacity-100');
            } else {
                valSpan.textContent = "0";
                valSpan.classList.add('opacity-0');
            }
        }
        
        if(costSpan) costSpan.className = "absolute top-1 right-2 text-xs text-slate-500 transition-all";

        if(data.active === key) {
            cell.classList.add('border-cyan-500', 'bg-cyan-950/30', 'shadow-[0_0_15px_rgba(34,211,238,0.2)]');
            if(valSpan) valSpan.classList.add('text-cyan-400', 'scale-110');
            if(costSpan) costSpan.classList.replace('text-slate-500', 'text-cyan-400');
        } else if (data.allocs[key] !== undefined) {
            if(valSpan) valSpan.classList.add('text-white');
        }

        const isRowCrossed = data.crossedRows.includes(r);
        const isColCrossed = data.crossedCols.includes(c);
        
        if ((isRowCrossed || isColCrossed) && data.active !== key) {
            cell.classList.replace('bg-slate-900', 'bg-slate-950');
            cell.classList.replace('border-slate-800', 'border-slate-900/50');
            if(costSpan) costSpan.classList.add('opacity-20');
            if(valSpan) valSpan.classList.add('opacity-40');
        }
      }
    }

    if (btnPrev) btnPrev.disabled = stepIdx === 0;
    if (btnNext) btnNext.disabled = stepIdx === steps.length - 1;
  }

  btnNext?.addEventListener('click', () => { if (stepIdx < steps.length - 1) { stepIdx++; renderStep(); } });
  btnPrev?.addEventListener('click', () => { if (stepIdx > 0) { stepIdx--; renderStep(); } });

  renderStep();
</script>