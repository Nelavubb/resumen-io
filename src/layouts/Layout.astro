---
interface Props {
	title: string;
}
const { title } = Astro.props;
import Navbar from '../components/Navbar.astro';
---

<!DOCTYPE html>
<html lang="es" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/logo.svg" />
		<title>{title}</title>
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
        <style>
            body { font-family: "Inter", sans-serif; }
        </style>
	</head>
	<body class="bg-slate-950 text-slate-300 selection:bg-cyan-500/30 selection:text-cyan-200 antialiased min-h-screen flex flex-col relative z-0">
		
        <div class="fixed inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-slate-900 via-slate-950 to-slate-950 -z-10"></div>
        
        <div class="fixed top-0 left-0 w-full h-1 bg-gradient-to-r from-cyan-500 via-blue-500 to-purple-500 z-50"></div>

        <Navbar />
		
        <main class="flex-grow max-w-5xl w-full mx-auto px-6 py-20 z-10 relative">
			<slot />
		</main>

		<footer class="mt-auto border-t border-slate-800/50 py-8 text-center text-slate-600 text-sm bg-slate-950/50 backdrop-blur-sm">
			<p>&copy; {new Date().getFullYear()} — IO Dashboard</p>
		</footer>
	</body>
</html>